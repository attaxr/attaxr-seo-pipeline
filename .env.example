# SEO Pipeline Configuration
# ── Browser Use API Key (REQUIRED for full article scraping) ──
# Get a free key at: https://cloud.browser-use.com/settings?tab=api-keys
# Your key starts with 'bu_'
# Run `python scripts/setup.py` for interactive setup.
BROWSER_USE_API_KEY=

# ── Browser Use Proxy Settings (optional) ────────────────────
# Residential proxy country code (ISO 3166-1 alpha-2, e.g. us, de, gb, jp)
# Leave empty for default (US residential proxy).
# Set to "none" to disable residential proxies entirely.
#BROWSER_USE_PROXY_COUNTRY=us

# Custom proxy server (HTTP or SOCKS5). Overrides the residential proxy when set.
# Format: proxy.example.com
#BROWSER_USE_CUSTOM_PROXY_HOST=
#BROWSER_USE_CUSTOM_PROXY_PORT=8080
#BROWSER_USE_CUSTOM_PROXY_USERNAME=
#BROWSER_USE_CUSTOM_PROXY_PASSWORD=

# ── Pipeline Configuration ───────────────────────────────────
# Directory for pipeline artifacts (keywords, articles, drafts)
# Defaults to ./pipeline_data/ if not set
#SEO_PIPELINE_DIR=./pipeline_data

# ── Optional — default author for generated articles ────────
#AUTHOR_NAME=Your Name
